# Production Environment Variables for Render.com
# Copy this to .env in Render Dashboard or use render.yaml

APP_NAME=MyPharma
APP_ENV=production
APP_DEBUG=false
APP_URL=https://mypharma-api.onrender.com
APP_FRONTEND_URL=https://mypharma-frontend.vercel.app

# Database (PostgreSQL on Render)
DB_CONNECTION=pgsql
DB_HOST=your-db-host.render.com
DB_PORT=5432
DB_DATABASE=mypharma
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password

# Cache & Session
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Queue
QUEUE_CONNECTION=sync

# Filesystem
FILESYSTEM_DISK=public

# Mail (use log in production for testing)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@mypharma.com"
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum
SANCTUM_STATEFUL_DOMAINS=mypharma-frontend.vercel.app
SESSION_DOMAIN=onrender.com
