# Production Environment Variables for Render.com
# Copy this to .env in Render Dashboard or use render.yaml

APP_NAME=MyPharma
APP_ENV=production
APP_DEBUG=false
APP_URL=https://mypharma-api.onrender.com
APP_FRONTEND_URL=https://mypharma-frontend.vercel.app

# Database (PostgreSQL on Render)
DB_CONNECTION=pgsql
DB_HOST=your-db-host.render.com
DB_PORT=5432
DB_DATABASE=mypharma
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password

# Cache & Session
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Queue
QUEUE_CONNECTION=sync

# Filesystem
FILESYSTEM_DISK=public
# Disque des fichiers uploadés (ordonnances, images produits).
# IMPORTANT : le disque "public" de Render est ÉPHÉMÈRE (fichiers perdus à chaque
# redéploiement). Pour la production, mettre UPLOADS_DISK=s3 et renseigner AWS_*.
UPLOADS_DISK=public
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
# AWS_BUCKET=
# AWS_URL=
# AWS_ENDPOINT=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# Paiement en ligne — laisser DÉSACTIVÉ tant que l'intégration réelle
# (Orange Money / Wave + webhook signé) n'est pas en place. Seul le paiement
# à la livraison est alors proposé.
PAYMENTS_ONLINE_ENABLED=false

# Mail (use log in production for testing)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@mypharma.com"
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum
SANCTUM_STATEFUL_DOMAINS=mypharma-frontend.vercel.app
SESSION_DOMAIN=onrender.com
# Durée de vie des tokens d'API en minutes (défaut : 7 jours).
SANCTUM_TOKEN_EXPIRATION=10080
